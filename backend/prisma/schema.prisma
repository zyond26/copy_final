generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── RBAC: Vai trò – Quyền (ISO 27799 §9.1.2, §9.6.1) ───────────────
model roles {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  users       users[]
  role_permissions role_permissions[]
}

model permissions {
  id       Int    @id @default(autoincrement())
  name     String @unique @db.VarChar(100) // vd: patient:create
  resource String @db.VarChar(50)          // patient, record, user...
  action   String @db.VarChar(30)          // create, read, update, delete...
  role_permissions role_permissions[]
}

model role_permissions {
  role_id       Int
  permission_id Int
  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([permission_id])
}

model audit_logs {
  id                 BigInt    @id @default(autoincrement())
  user_id            BigInt?
  patient_id         BigInt?
  action             String?   @db.VarChar(100)
  entity_type        String?   @db.VarChar(50)
  entity_id          BigInt?
  ip_address         String?   @db.VarChar(50)
  user_agent         String?   @db.VarChar(255)
  status             String?   @default("SUCCESS")
  old_value          Json?     //Data before modification (null if CREATE)
  new_value          Json?     //Data after modification (null if DELETE)
  break_glass        Boolean?  @default(false)
  break_glass_reason String?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  patients           patients? @relation(fields: [patient_id], references: [id], onUpdate: NoAction, map: "fk_log_patient")
  users              users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_log_user")

  @@index([action], map: "idx_log_action")
  @@index([patient_id], map: "idx_log_patient")
  @@index([user_id], map: "idx_log_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model medical_records {
  id            BigInt          @id @default(autoincrement())
  record_code   String          @unique @db.VarChar(20)
  patient_id    BigInt
  doctor_id     BigInt
  symptoms      String?
  diagnosis     String?
  conclusion    String?
  visit_date    DateTime?       @default(now()) @db.Timestamp(6)
  status        String?         @default("OPEN") @db.VarChar(20)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  users         users           @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_record_doctor")
  patients      patients        @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_record_patient")
  prescriptions           prescriptions[]
  vital_signs             vital_signs[]
  medical_record_versions medical_record_versions[]

  @@index([doctor_id], map: "idx_record_doctor")
  @@index([patient_id], map: "idx_record_patient")
}

model otp_verifications {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  otp_code   String    @db.VarChar(10)
  expired_at DateTime  @db.Timestamp(6)
  verified   Boolean?  @default(false)
  attempts   Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_otp_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model patients {
  id              BigInt            @id @default(autoincrement())
  patient_code    String            @unique @db.VarChar(20)
  full_name       String            @db.VarChar(100)
  dob             DateTime?         @db.Date
  gender          String?           @db.VarChar(10)
  phone           String?           @db.VarChar(20)
  email           String?           @db.VarChar(100)
  address         String?
  citizen_id      String?           @unique @db.VarChar(20)
  user_id         BigInt?           @unique
  created_by      BigInt?
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  updated_at      DateTime?         @default(now()) @db.Timestamp(6)
  audit_logs      audit_logs[]
  medical_records medical_records[]
  break_glass     break_glass[]
  appointments    appointments[]
  user_account    users?            @relation("patient_account", fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_patient_account")
  users           users?            @relation("patient_creator", fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_patient_creator")

  @@index([patient_code], map: "idx_patient_code")
  @@index([full_name], map: "idx_patient_name")
}

model prescription_items {
  id              BigInt        @id @default(autoincrement())
  prescription_id BigInt
  medicine_name   String        @db.VarChar(255)
  dosage          String?       @db.VarChar(100)
  frequency       String?       @db.VarChar(100)
  duration_days   Int?
  instruction     String?
  prescriptions   prescriptions @relation(fields: [prescription_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_prescription_item")
}

model prescriptions {
  id                 BigInt               @id @default(autoincrement())
  medical_record_id  BigInt
  doctor_id          BigInt
  note               String?
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  prescription_items prescription_items[]
  users              users                @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_prescription_doctor")
  medical_records    medical_records      @relation(fields: [medical_record_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_prescription_record")

  @@index([medical_record_id], map: "idx_prescription_record")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                BigInt              @id @default(autoincrement())
  username          String              @unique @db.VarChar(50)
  password_hash     String
  email             String              @unique @db.VarChar(100)
  full_name         String              @db.VarChar(100)
  citizen_id        String?             @unique @db.VarChar(20)
  role_id           Int?
  status            String?             @default("PENDING") @db.VarChar(20)
  mfa_enabled       Boolean?            @default(true)
  failed_login_attempts Int?            @default(0)
  locked_until      DateTime?           @db.Timestamp(6)
  password_changed_at DateTime?         @default(now()) @db.Timestamp(6)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  updated_at        DateTime?           @default(now()) @db.Timestamp(6)
  audit_logs              audit_logs[]
  medical_records         medical_records[]
  otp_verifications       otp_verifications[]
  patient_profile         patients?                 @relation("patient_account")
  patients                patients[]                @relation("patient_creator")
  prescriptions           prescriptions[]
  vital_signs             vital_signs[]
  medical_record_versions medical_record_versions[]
  break_glass_requested   break_glass[]             @relation("BreakGlassRequester")
  break_glass_approved    break_glass[]             @relation("BreakGlassApprover")
  role_ref                roles?                    @relation(fields: [role_id], references: [id], onUpdate: NoAction)
  appointments            appointments[]
}

model vital_signs {
  id                BigInt          @id @default(autoincrement())
  medical_record_id BigInt
  nurse_id          BigInt
  temperature       Decimal?        @db.Decimal(4, 1)
  blood_pressure    String?         @db.VarChar(20)
  heart_rate        Int?
  spo2              Int?
  weight            Decimal?        @db.Decimal(5, 2)
  note              String?
  created_at        DateTime?       @default(now()) @db.Timestamp(6)
  users             users           @relation(fields: [nurse_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vital_nurse")
  medical_records   medical_records @relation(fields: [medical_record_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vital_record")
}

model break_glass {
  id                  BigInt    @id @default(autoincrement())
  requested_by        BigInt
  patient_id          BigInt
  reason              String    @db.Text
  status              String    @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  approved_by         BigInt?
  approved_at         DateTime?
  expires_at          DateTime?
  created_at          DateTime  @default(now()) @db.Timestamp(6)

  requester           users     @relation("BreakGlassRequester", fields: [requested_by], references: [id])
  approver            users?    @relation("BreakGlassApprover", fields: [approved_by], references: [id])
  patient             patients  @relation(fields: [patient_id], references: [id])

  @@index([status])
  @@index([patient_id])
  @@index([requested_by])
}
model medical_record_versions {
  id                BigInt    @id @default(autoincrement())
  medical_record_id BigInt
  record_code       String    @db.VarChar(20)
  patient_id        BigInt
  doctor_id         BigInt
  symptoms          String?
  diagnosis         String?
  conclusion        String?
  visit_date        DateTime? @db.Timestamp(6)
  status            String?   @db.VarChar(20)
  version           Int
  changed_by        BigInt
  changed_at        DateTime  @default(now()) @db.Timestamp(6)

  medical_records   medical_records @relation(fields: [medical_record_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ver_record")
  users             users           @relation(fields: [changed_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ver_user")

  @@index([medical_record_id], map: "idx_ver_record")
  @@index([changed_by], map: "idx_ver_user")
}

model appointments {
  id                BigInt          @id @default(autoincrement())
  appointment_code  String          @unique @db.VarChar(20)
  patient_id        BigInt
  doctor_id         BigInt
  appointment_date  DateTime        @db.Timestamp(6)
  status            String          @default("PENDING") @db.VarChar(20)
  reason            String?         @db.Text
  notes             String?         @db.Text
  created_at        DateTime        @default(now()) @db.Timestamp(6)
  updated_at        DateTime        @default(now()) @db.Timestamp(6)

  patient           patients        @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  doctor            users           @relation(fields: [doctor_id], references: [id], onDelete: Cascade)

  @@index([patient_id])
  @@index([doctor_id])
  @@index([status])
}
